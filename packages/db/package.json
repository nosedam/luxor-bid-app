{
  "name": "@workspace/db",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "db:generate": "dotenv -e ../../apps/web/.env -- prisma generate",
    "db:migrate": "dotenv -e ../../apps/web/.env -- prisma migrate dev",
    "db:push": "dotenv -e ../../apps/web/.env -- prisma db push",
    "db:seed": "dotenv -e ../../apps/web/.env -- prisma db seed"
  },
  "prisma": {
    "seed": "dotenv -e ../../apps/web/.env -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.2",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": "./src/index.ts"
  }
}
